<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.AlbumsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:FloatHearing.Models"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:CoverPathToImageSourceConverter x:Key="CoverPathToImageSourceConverter" />

        <DataTemplate x:Key="AlbumItemTemplate" x:DataType="models:Album">
            <Grid Padding="8" Width="180">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Width="164"
                    Height="164"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid>
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Glyph="&#xE8B7;"
                            FontSize="48"
                            Opacity="0.5" />
                        <Image
                            Source="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToImageSourceConverter}, ConverterParameter=400}"
                            Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Text="{x:Bind Title, Mode=OneTime}"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="2"
                    Text="{x:Bind Artist, Mode=OneTime}"
                    Opacity="0.7"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="专辑"
            FontSize="24"
            FontWeight="SemiBold"
            Margin="0,0,0,16" />

        <GridView
            Grid.Row="1"
            x:Name="AlbumsGridView"
            ItemsSource="{x:Bind ViewModel.Albums}"
            ItemTemplate="{StaticResource AlbumItemTemplate}"
            IsItemClickEnabled="True"
            ItemClick="AlbumsGridView_ItemClick" />
    </Grid>
</Page>
