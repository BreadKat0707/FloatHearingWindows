<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.ArtistDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:FloatHearing.Models"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:CoverPathToImageSourceConverter x:Key="CoverPathToImageSourceConverter" />

        <DataTemplate x:Key="AlbumItemTemplate" x:DataType="models:Album">
            <Grid Padding="8" Width="160">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Width="144"
                    Height="144"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid>
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Glyph="&#xE8B7;"
                            FontSize="48"
                            Opacity="0.5" />
                        <Image
                            Source="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToImageSourceConverter}, ConverterParameter=300}"
                            Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Text="{x:Bind Title, Mode=OneTime}"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="2"
                    Text="{x:Bind TotalDuration, Mode=OneTime, Converter={StaticResource TimeSpanToStringConverter}}"
                    Opacity="0.7"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <Button
                x:Name="BackButton"
                Click="BackButton_Click"
                Style="{StaticResource NavigationBackButtonNormalStyle}"
                HorizontalAlignment="Left"
                Margin="-8,0,0,0" />

            <TextBlock
                Text="艺术家"
                FontSize="14"
                Opacity="0.7" />
            <TextBlock
                Text="{x:Bind ViewModel.Artist.Name, Mode=OneTime, FallbackValue='未知艺术家'}"
                FontSize="32"
                FontWeight="Bold" />
            <TextBlock Opacity="0.7">
                <Run Text="{x:Bind ViewModel.Artist.SongCount, Mode=OneTime}" />
                <Run Text="首歌曲 · " />
                <Run Text="{x:Bind ViewModel.Artist.AlbumCount, Mode=OneTime}" />
                <Run Text="张专辑" />
            </TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">
                <!-- 歌曲 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="歌曲" FontSize="20" FontWeight="SemiBold" />
                    <ListView
                        x:Name="SongsListView"
                        ItemsSource="{x:Bind ViewModel.Songs}"
                        IsItemClickEnabled="True"
                        ItemClick="SongsListView_ItemClick"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Grid Padding="8,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Text="{x:Bind TrackNumber, Mode=OneTime, FallbackValue=''}"
                                        Opacity="0.6" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock
                                            Text="{x:Bind Title, Mode=OneTime}"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Text="{x:Bind Album, Mode=OneTime}"
                                            Opacity="0.7"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Duration, Mode=OneTime, Converter={StaticResource TimeSpanToStringConverter}}"
                                        Opacity="0.7" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- 专辑 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="专辑" FontSize="20" FontWeight="SemiBold" />
                    <GridView
                        x:Name="AlbumsGridView"
                        ItemsSource="{x:Bind ViewModel.Albums}"
                        ItemTemplate="{StaticResource AlbumItemTemplate}"
                        IsItemClickEnabled="True"
                        ItemClick="AlbumsGridView_ItemClick" />
                </StackPanel>

                <!-- 参与的专辑 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="参与的专辑" FontSize="20" FontWeight="SemiBold" />
                    <GridView
                        x:Name="FeaturedAlbumsGridView"
                        ItemsSource="{x:Bind ViewModel.FeaturedAlbums}"
                        ItemTemplate="{StaticResource AlbumItemTemplate}"
                        IsItemClickEnabled="True"
                        ItemClick="FeaturedAlbumsGridView_ItemClick" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
