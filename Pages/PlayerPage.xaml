<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
        <converters:CoverPathToImageSourceConverter x:Key="CoverPathToImageSourceConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:BooleanToPlayPauseSymbolConverter x:Key="BooleanToPlayPauseSymbolConverter" />
    </Page.Resources>

    <Grid Padding="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部返回按钮 -->
        <Button
            Grid.Row="0"
            x:Name="BackButton"
            Click="BackButton_Click"
            Style="{StaticResource NavigationBackButtonNormalStyle}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="-8,0,0,0" />

        <!-- 中间：大封面和歌曲信息 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Width="360"
                    Height="360"
                    CornerRadius="16"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    Margin="0,0,0,32">
                    <Grid>
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Glyph="&#xE8B7;"
                            FontSize="120"
                            Opacity="0.4" />
                        <Image
                            Source="{Binding CurrentSong.CoverPath, Mode=OneWay, Converter={StaticResource CoverPathToImageSourceConverter}}"
                            Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock
                        Text="{Binding CurrentSong.Title, Mode=OneWay, FallbackValue='未在播放'}"
                        FontSize="28"
                        FontWeight="SemiBold"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis" />
                    
                    <TextBlock
                        Text="{Binding CurrentSong.Artist, Mode=OneWay, FallbackValue=''}"
                        FontSize="18"
                        Opacity="0.8"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis" />
                    
                    <TextBlock
                        Text="{Binding CurrentSong.Album, Mode=OneWay, FallbackValue=''}"
                        FontSize="16"
                        Opacity="0.6"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- 底部控制区 -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 进度条和时间 -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{Binding CurrentPosition, Mode=OneWay, Converter={StaticResource SecondsToTimeConverter}}"
                    Opacity="0.8"
                    Width="48" />

                <Slider
                    Grid.Column="1"
                    x:Name="PositionSlider"
                    Margin="12,0"
                    VerticalAlignment="Center"
                    Maximum="{Binding Duration, Mode=OneWay}"
                    Minimum="0"
                    StepFrequency="1"
                    ThumbToolTipValueConverter="{StaticResource SecondsToTimeConverter}"
                    Value="{Binding CurrentPosition, Mode=TwoWay}" />

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{Binding Duration, Mode=OneWay, Converter={StaticResource SecondsToTimeConverter}}"
                    Opacity="0.8"
                    Width="48" />
            </Grid>

            <!-- 播放控制按钮 -->
            <StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="24">
                <Button
                    x:Name="PreviousButton"
                    Click="PreviousButton_Click"
                    ToolTipService.ToolTip="上一首"
                    Style="{StaticResource ButtonRevealStyle}">
                    <SymbolIcon Symbol="Previous" />
                </Button>
                <Button
                    x:Name="PlayPauseButton"
                    Click="PlayPauseButton_Click"
                    Width="64"
                    Height="64"
                    CornerRadius="32"
                    ToolTipService.ToolTip="播放 / 暂停"
                    Style="{StaticResource AccentButtonStyle}">
                    <SymbolIcon Symbol="{Binding IsPlaying, Mode=OneWay, Converter={StaticResource BooleanToPlayPauseSymbolConverter}}" />
                </Button>
                <Button
                    x:Name="NextButton"
                    Click="NextButton_Click"
                    ToolTipService.ToolTip="下一首"
                    Style="{StaticResource ButtonRevealStyle}">
                    <SymbolIcon Symbol="Next" />
                </Button>
            </StackPanel>

            <!-- 音量 -->
            <StackPanel
                Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12"
                Margin="0,16,0,0">
                <FontIcon Glyph="&#xE767;" FontSize="16" Opacity="0.7" />
                <Slider
                    Width="200"
                    Maximum="1"
                    Minimum="0"
                    StepFrequency="0.01"
                    Value="{Binding Volume, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
