<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.ArtistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:FloatHearing.Models"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />

        <DataTemplate x:Key="ArtistItemTemplate" x:DataType="models:Artist">
            <Grid Padding="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Glyph="&#xE77B;"
                    FontSize="32"
                    Margin="0,0,16,0"
                    Opacity="0.6" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        Text="{x:Bind Name, Mode=OneTime}"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Text="{x:Bind SongCount, Mode=OneTime}"
                        Opacity="0.7" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="艺术家"
            FontSize="24"
            FontWeight="SemiBold"
            Margin="0,0,0,16" />

        <ListView
            Grid.Row="1"
            x:Name="ArtistsListView"
            ItemsSource="{x:Bind ViewModel.Artists}"
            ItemTemplate="{StaticResource ArtistItemTemplate}"
            IsItemClickEnabled="True"
            ItemClick="ArtistsListView_ItemClick" />
    </Grid>
</Page>
