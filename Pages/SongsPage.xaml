<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.SongsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:FloatHearing.Models"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:core="using:FloatHearing.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:CoverPathToImageSourceConverter x:Key="CoverPathToImageSourceConverter" />
        <converters:StringToVisibilityConverter x:Key="CoverPathToVisibilityConverter" />
        <converters:SongItemLayoutConverter x:Key="SongItemLayoutConverter" />

        <DataTemplate x:Key="SongItemTemplate" x:DataType="models:Song">
            <Grid Padding="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=Padding}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Width="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=CoverSize}" Height="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=CoverSize}" Margin="0,0,{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=CoverMargin},0">
                    <Image
                        Stretch="UniformToFill"
                        Source="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToImageSourceConverter}}"
                        Visibility="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToVisibilityConverter}}" />
                    <FontIcon
                        Glyph="&#xE8D6;"
                        FontSize="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=IconFontSize}"
                        Opacity="0.6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToVisibilityConverter}, ConverterParameter=Invert}" />
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        Text="{x:Bind Title, Mode=OneTime}"
                        FontSize="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=TitleFontSize}"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Text="{x:Bind Artist, Mode=OneTime}"
                        FontSize="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=SubtitleFontSize}"
                        Opacity="0.7"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=DurationFontSize}"
                    Opacity="0.7"
                    Text="{x:Bind Duration, Mode=OneTime, Converter={StaticResource TimeSpanToStringConverter}}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="PageTitle"
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="SemiBold"
                Text="歌曲" />
            <StackPanel
                x:Name="ToolbarRight"
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">
                <StackPanel
                    x:Name="ScanProgressPanel"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressRing Width="16" Height="16" IsActive="True" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" />
                </StackPanel>
                <ComboBox
                    x:Name="SortFieldComboBox"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.SortFields}"
                    SelectedItem="{x:Bind ViewModel.CurrentSortField, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="core:SongSortField">
                            <TextBlock Text="{x:Bind}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button
                    x:Name="SortDirectionButton"
                    Click="SortDirectionButton_Click"
                    ToolTipService.ToolTip="切换升序/降序">
                    <SymbolIcon Symbol="Sort" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- 音乐列表 -->
        <ListView
            x:Name="SongsListView"
            Grid.Row="1"
            Padding="0"
            CornerRadius="8"
            IsItemClickEnabled="True"
            ItemClick="SongsListView_ItemClick"
            ItemTemplate="{StaticResource SongItemTemplate}"
            ItemsSource="{x:Bind ViewModel.Songs}"
            SelectionChanged="SongsListView_SelectionChanged"
            SelectionMode="Single" />
    </Grid>
</Page>
