<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.SongsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:FloatHearing.Models"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:core="using:FloatHearing.Core.Models"
    xmlns:data="using:FloatHearing.Data.Entities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:CoverPathToImageSourceConverter x:Key="CoverPathToImageSourceConverter" />
        <converters:StringToVisibilityConverter x:Key="CoverPathToVisibilityConverter" />

        <DataTemplate x:Key="SongItemTemplate" x:DataType="models:Song">
            <Grid Padding="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,12,0">
                    <Image
                        Stretch="UniformToFill"
                        Source="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToImageSourceConverter}}"
                        Visibility="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToVisibilityConverter}}" />
                    <FontIcon
                        Glyph="&#xE8D6;"
                        FontSize="24"
                        Opacity="0.6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToVisibilityConverter}, ConverterParameter=Invert}" />
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        Text="{x:Bind Title, Mode=OneTime}"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Text="{x:Bind Artist, Mode=OneTime}"
                        Opacity="0.7"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Opacity="0.7"
                    Text="{x:Bind Duration, Mode=OneTime, Converter={StaticResource TimeSpanToStringConverter}}" />
            </Grid>
        </DataTemplate>

        <MenuFlyout x:Key="SongContextMenuFlyout">
            <MenuFlyoutItem Text="立即播放" Click="PlayNowMenuItem_Click" />
            <MenuFlyoutItem Text="下一首播放" Click="PlayNextMenuItem_Click" />
            <MenuFlyoutSeparator />
            <MenuFlyoutSubItem Text="专辑" FontFamily="Microsoft YaHei UI">
                <MenuFlyoutItem Text="查看专辑" Click="ViewAlbumMenuItem_Click" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem Text="艺术家" FontFamily="Microsoft YaHei UI">
                <MenuFlyoutItem Text="查看艺术家" Click="ViewArtistMenuItem_Click" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="在资源管理器中定位" Click="OpenContainingFolderMenuItem_Click" />
            <MenuFlyoutItem Text="选择其他应用打开" Click="OpenWithExternalAppMenuItem_Click" />
            <MenuFlyoutSubItem Text="复制" FontFamily="Microsoft YaHei UI">
                <MenuFlyoutItem Text="复制歌曲名称" Click="CopySongNameMenuItem_Click" />
                <MenuFlyoutItem Text="复制文件路径" Click="CopyFilePathMenuItem_Click" />
            </MenuFlyoutSubItem>
            <MenuFlyoutItem Text="音乐标签与文件属性" Click="PropertiesMenuItem_Click" />
            <MenuFlyoutItem Text="从文件重新读取音轨信息" Click="RescanMetadataMenuItem_Click" />
            <MenuFlyoutSeparator />
            <MenuFlyoutSubItem Text="添加到歌单" x:Name="AddToPlaylistSubMenu" FontFamily="Microsoft YaHei UI">
            </MenuFlyoutSubItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="从音乐库中移除" Click="RemoveFromLibraryMenuItem_Click" />
            <MenuFlyoutItem Text="从本地磁盘中删除" Click="DeleteFromDiskMenuItem_Click" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="同名搜索" Click="SearchSameNameMenuItem_Click" />
        </MenuFlyout>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="PageTitle"
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="SemiBold"
                Text="歌曲" />
            <StackPanel
                x:Name="ToolbarRight"
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">
                <StackPanel
                    x:Name="ScanProgressPanel"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressRing Width="16" Height="16" IsActive="True" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" />
                </StackPanel>
                <ComboBox
                    x:Name="SortFieldComboBox"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.SortFields}"
                    SelectedItem="{x:Bind ViewModel.CurrentSortField, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="core:SongSortField">
                            <TextBlock Text="{x:Bind}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button
                    x:Name="SortDirectionButton"
                    Click="SortDirectionButton_Click"
                    ToolTipService.ToolTip="切换升序/降序">
                    <SymbolIcon Symbol="Sort" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- 音乐列表 -->
        <ListView
            x:Name="SongsListView"
            Grid.Row="1"
            Padding="0"
            CornerRadius="8"
            IsItemClickEnabled="True"
            ItemClick="SongsListView_ItemClick"
            ItemTemplate="{StaticResource SongItemTemplate}"
            ItemsSource="{x:Bind ViewModel.Songs}"
            RightTapped="SongsListView_RightTapped"
            SelectionChanged="SongsListView_SelectionChanged"
            SelectionMode="Single" />
    </Grid>
</Page>
