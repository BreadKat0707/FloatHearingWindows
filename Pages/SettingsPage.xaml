<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:entities="using:FloatHearing.Data.Entities"
    xmlns:converters="using:FloatHearing.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:DateTimeToLocalStringConverter x:Key="DateTimeToLocalStringConverter" />
        <converters:SongItemLayoutConverter x:Key="SongItemLayoutConverter" />
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="PageTitle"
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="SemiBold"
                Text="扫描目录" />

            <StackPanel
                x:Name="ToolbarRight"
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">
                <StackPanel
                    x:Name="ScanProgressPanel"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressRing Width="16" Height="16" IsActive="True" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" />
                </StackPanel>

                <Button
                    x:Name="ScanAllButton"
                    Click="ScanAllButton_Click"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                    Margin="0,0,8,0"
                    ToolTipService.ToolTip="立即扫描所有目录">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="全部扫描" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="AddFolderButton"
                    Click="AddFolderButton_Click"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                    ToolTipService.ToolTip="添加音乐文件夹">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock Text="添加目录" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ListView
            x:Name="ScanPathsListView"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.ScanPaths}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="entities:ScanPathEntity">
                    <Grid Padding="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=Padding}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                Text="{x:Bind Path, Mode=OneTime}"
                                FontSize="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=TitleFontSize}"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Opacity="0.7"
                                FontSize="{x:Bind Converter={StaticResource SongItemLayoutConverter}, ConverterParameter=SubtitleFontSize}"
                                Text="{x:Bind CreatedAt, Mode=OneTime, Converter={StaticResource DateTimeToLocalStringConverter}}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Click="DeleteScanPathButton_Click"
                            Tag="{x:Bind Id, Mode=OneTime}"
                            ToolTipService.ToolTip="删除">
                            <SymbolIcon Symbol="Delete" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
