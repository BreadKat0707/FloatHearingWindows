<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FloatHearing.Pages.AlbumDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:FloatHearing.Models"
    xmlns:converters="using:FloatHearing.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
        <converters:CoverPathToImageSourceConverter x:Key="CoverPathToImageSourceConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 专辑头部信息 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Width="200"
                Height="200"
                Margin="0,0,24,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="12">
                <Grid>
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Glyph="&#xE8B7;"
                        FontSize="72"
                        Opacity="0.5" />
                    <Image
                        Source="{x:Bind ViewModel.Album.CoverPath, Mode=OneTime, Converter={StaticResource CoverPathToImageSourceConverter}, ConverterParameter=400}"
                        Stretch="UniformToFill" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="8">
                <TextBlock
                    Text="专辑"
                    FontSize="14"
                    Opacity="0.7" />
                <TextBlock
                    Text="{x:Bind ViewModel.Album.Title, Mode=OneTime}"
                    FontSize="32"
                    FontWeight="Bold"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Text="{x:Bind ViewModel.Album.Artist, Mode=OneTime}"
                    FontSize="18"
                    Opacity="0.8"
                    TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Spacing="16" Opacity="0.7">
                    <TextBlock>
                        <Run Text="{x:Bind ViewModel.Album.SongCount, Mode=OneTime}" />
                        <Run Text="首歌曲" />
                    </TextBlock>
                    <TextBlock Text="{x:Bind ViewModel.Album.TotalDuration, Mode=OneTime, Converter={StaticResource TimeSpanToStringConverter}}" />
                    <TextBlock Text="{x:Bind ViewModel.Album.ReleaseDateText, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 曲目列表 -->
        <ListView
            Grid.Row="1"
            x:Name="SongsListView"
            IsItemClickEnabled="True"
            ItemClick="SongsListView_ItemClick"
            ItemsSource="{x:Bind ViewModel.Songs}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Song">
                    <Grid Padding="8,12" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Text="{x:Bind TrackNumber, Mode=OneTime, FallbackValue=''}"
                            Opacity="0.6" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                Text="{x:Bind Title, Mode=OneTime}"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Text="{x:Bind Artist, Mode=OneTime}"
                                Opacity="0.7"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Text="{x:Bind Duration, Mode=OneTime, Converter={StaticResource TimeSpanToStringConverter}}"
                            Opacity="0.7" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
